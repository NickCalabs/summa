# -----------------------------------------------------------------------
# Required — app will not start without these
# -----------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgres://summa:summa@localhost:5432/summa

# Secret used by Better Auth for session signing. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Base URL of the application (used by Better Auth for redirects/callbacks)
BETTER_AUTH_URL=http://localhost:3000

# 64-character hex string (32 bytes) used for AES-256-GCM encryption.
# Required in production — app will exit on startup if absent.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32-and-paste-result-here

# -----------------------------------------------------------------------
# Optional — Etherscan API (required for ETH wallet tracking)
# -----------------------------------------------------------------------
# Free tier: 5 calls/sec, 100k calls/day. Get one at https://etherscan.io/myapikey
# ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------
# Optional — Plaid bank connections (leave blank to disable)
# -----------------------------------------------------------------------
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_WEBHOOK_SECRET=  # Set any non-empty value to enable webhook signature verification
# PLAID_PRODUCTS=balance,investments,liabilities,transactions  # Comma-separated; defaults to balance,investments,liabilities,transactions
