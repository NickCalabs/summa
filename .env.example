DATABASE_URL=postgres://summa:summa@localhost:5432/summa

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Required in production — generate with: openssl rand -hex 32
# Must be a 64-character hex string (32 bytes). Do NOT leave as default in production.
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string-generated-with-openssl-rand

# Optional — Plaid bank connections (leave blank to disable)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_WEBHOOK_SECRET=  # Set any non-empty value to enable webhook signature verification

# Optional — 32-byte hex string for encrypting Plaid tokens (derived from BETTER_AUTH_SECRET if absent)
# ENCRYPTION_KEY=
